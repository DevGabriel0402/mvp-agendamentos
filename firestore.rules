rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções auxiliares
    function isLogado() {
      return request.auth != null;
    }

    // Pega os dados do administrador logado com segurança
    function getAdminData() {
      let userPath = /databases/$(database)/documents/administradores/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }
    
    // COLEÇÃO: empresas (Leitura pública, escrita Master ou Admin da própria empresa)
    match /empresas/{empresaId} {
      allow read: if true;
      allow write: if isLogado() && getAdminData() != null && (
        getAdminData().permissoes == 'master' || 
        getAdminData().empresaId == empresaId || 
        getAdminData().empresaId == resource.data.slug
      );
    }

    // COLEÇÃO: administradores (Usuário só lê/escreve o seu próprio perfil pelo UID)
    match /administradores/{uid} {
      allow read, write: if isLogado() && request.auth.uid == uid;
      allow list: if isLogado() && getAdminData() != null && (getAdminData().permissoes == 'master');
    }

    // COLEÇÃO: agendamentos (Clientes leem ocupação e criam, Admin gerencia tudo)
    match /agendamentos/{id} {
      allow read: if true; // Aberto para consulta de disponibilidade
      allow create: if true; // Aberto para clientes agendarem
      allow update, delete: if isLogado() && (
        (getAdminData() != null && (getAdminData().permissoes == 'master' || resource.data.empresaId == getAdminData().empresaId)) ||
        (!('empresaId' in resource.data) || resource.data.empresaId == null) ||
        (resource.data.userId == request.auth.uid)
      );
    }

    // COLEÇÃO: clientes (Clientes podem ser criados, Admin gerencia lista)
    match /clientes/{id} {
      allow read: if true; // Facilitar consulta de cliente pelo CPF/Contato no agendamento
      allow create: if true; // Clientes novos podem ser cadastrados no agendamento
      allow update, delete: if isLogado() && (
        (getAdminData() != null && (getAdminData().permissoes == 'master' || resource.data.empresaId == getAdminData().empresaId)) ||
        (!('empresaId' in resource.data) || resource.data.empresaId == null)
      );
    }

    // REGRAS PARA OUTROS DADOS (servicos, feedbacks, configuracoes)
    match /{colecao}/{docId} {
      allow read: if true; 
      
      allow write: if isLogado() && (
        (getAdminData() != null && getAdminData().permissoes == 'master') ||
        (getAdminData() != null && resource != null && resource.data.empresaId == getAdminData().empresaId) ||
        (resource == null) ||
        (!('empresaId' in resource.data) || resource.data.empresaId == null)
      );
    }
  }
}
